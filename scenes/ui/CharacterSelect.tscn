[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/character_select.gd" id="1"]

[node name="CharacterSelect" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchor_left = 0.2
anchor_top = 0.15
anchor_right = 0.8
anchor_bottom = 0.85
grow_horizontal = 2
grow_vertical = 2
alignment = 1

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Choose Your Party"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="CharacterRow" type="HBoxContainer" parent="VBox"]
layout_mode = 2

[node name="LancerPanel" type="VBoxContainer" parent="VBox/CharacterRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="LancerName" type="Label" parent="VBox/CharacterRow/LancerPanel"]
layout_mode = 2
text = "Lancer"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20

[node name="LancerHP" type="Label" parent="VBox/CharacterRow/LancerPanel"]
layout_mode = 2
text = "HP: 50"
horizontal_alignment = 1

[node name="LancerDesc" type="Label" parent="VBox/CharacterRow/LancerPanel"]
layout_mode = 2
text = "Momentum and commitment. Devastating when conditions are met."
horizontal_alignment = 1
autowrap_mode = 2

[node name="JesterPanel" type="VBoxContainer" parent="VBox/CharacterRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="JesterName" type="Label" parent="VBox/CharacterRow/JesterPanel"]
layout_mode = 2
text = "Jester"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20

[node name="JesterHP" type="Label" parent="VBox/CharacterRow/JesterPanel"]
layout_mode = 2
text = "HP: 50"
horizontal_alignment = 1

[node name="JesterDesc" type="Label" parent="VBox/CharacterRow/JesterPanel"]
layout_mode = 2
text = "Manipulates the order of events and creates impossible situations."
horizontal_alignment = 1
autowrap_mode = 2

[node name="DescendButton" type="Button" parent="VBox"]
layout_mode = 2
text = "Descend"

[connection signal="pressed" from="VBox/DescendButton" to="." method="_on_descend_button_pressed"]
